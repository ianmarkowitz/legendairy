# ─────────────────────────────────────────────────────────────────────────────
# LEGENDAIRY ICE CREAM — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Keep secret — server only

# ── Anthropic ─────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...    # or pk_test_... for dev
STRIPE_SECRET_KEY=sk_live_...                     # or sk_test_... for dev — server only

# Webhook secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# For local dev: use `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and copy the whsec_... value it prints.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (transactional email) ──────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000    # Change to https://legendairyicecream.com in production
